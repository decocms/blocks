{
  "name": "@decocms/admin",
  "version": "0.0.0",
  "type": "module",
  "description": "Deco admin protocol: /live/_meta, /.decofile, /deco/invoke, /deco/render, plus admin-facing site setup and commerce-app auto-configuration",
  "main": "./src/admin/index.ts",
  "exports": {
    ".": "./src/admin/index.ts",
    "./setup": "./src/createAdminSetup.ts",
    "./admin/setup": "./src/admin/setup.ts",
    "./apps": "./src/apps/index.ts",
    "./apps/autoconfig": "./src/apps/autoconfig.ts",
    "./sdk/htmlShell": "./src/sdk/htmlShell.ts",
    "./sdk/setupApps": "./src/sdk/setupApps.ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --root ../.. packages/admin",
    "typecheck": "tsc --noEmit",
    "lint:unused": "knip"
  },
  "dependencies": {
    "@decocms/live": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "knip": "^5.86.0",
    "typescript": "^5.9.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
