  "dependencies": {
    "@decocms/blocks": "workspace:*",
    "@decocms/apps-commerce": "workspace:*"
  },
  "peerDependencies": { "react": "^19.0.0", "react-dom": "^19.0.0" },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "knip": "^5.86.0",
    "typescript": "^5.9.0"
  },
  "publishConfig": { "registry": "https://registry.npmjs.org", "access": "public" }
