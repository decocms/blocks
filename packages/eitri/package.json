{
  "name": "@decocms/eitri",
  "version": "0.0.0",
  "type": "module",
  "description": "Deco binding for the Eitri mobile stack: produces a well-filled .deco (self-contained schema + decofile snapshot) so Studio can author content. No rendering — Eitri renders natively.",
  "repository": {
    "type": "git",
    "url": "https://github.com/decocms/blocks.git",
    "directory": "packages/eitri"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tsconfig": "./configs/tsconfig.json",
    "./types": "./types/eitri-luminus.d.ts"
  },
  "bin": {
    "deco-eitri": "./src/cli.ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --root ../.. packages/eitri/",
    "typecheck": "tsc --noEmit",
    "lint:unused": "knip"
  },
  "dependencies": {
    "@decocms/blocks-cli": "workspace:*",
    "tsx": "^4.22.5"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "knip": "^5.86.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
