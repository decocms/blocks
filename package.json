{
  "name": "decocms-start",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "packageManager": "bun@1.3.5",
  "scripts": {
    "build": "bun run --filter='./packages/*' build",
    "test": "bun run --filter='./packages/*' test",
    "typecheck": "bun run --filter='./packages/*' typecheck",
    "lint": "biome check packages/*/src packages/*/scripts",
    "lint:fix": "biome check --write packages/*/src packages/*/scripts",
    "lint:unused": "bun run --filter='./packages/*' lint:unused",
    "format": "biome format packages/*/src packages/*/scripts",
    "format:fix": "biome format --write packages/*/src packages/*/scripts",
    "check": "bun run typecheck && bun run lint && bun run lint:unused",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist .cache .wrangler/state node_modules/.vite && bun install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0",
    "jsdom": "^29.0.0"
  }
}
